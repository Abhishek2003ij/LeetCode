class Solution {
    public ListNode mergeTwoLists(ListNode list1, ListNode list2) {
        ListNode dummy = new ListNode(-1); // dummy head
        ListNode tail = dummy; // pointer to build the merged list
        
        while (list1 != null && list2 != null) {
            if (list1.val <= list2.val) {
                tail.next = list1; // attach list1 node
                list1 = list1.next; // move list1 pointer
            } else {
                tail.next = list2; // attach list2 node
                list2 = list2.next; // move list2 pointer
            }
            tail = tail.next; // move tail pointer
        }
        
        // Attach the remaining nodes (only one of these will run)
        if (list1 != null) tail.next = list1;
        if (list2 != null) tail.next = list2;
        
        return dummy.next; // skip dummy head
    }
}
