class Solution {
    public int maximumWealth(int[][] nums) {
        int m = nums.length;
        int  n = nums[0].length;
        int res = Integer.MIN_VALUE;
        for(int i=0;i<m;i++)
        {
            int sum =0;
            for(int j =0;j<n;j++)
            {
                sum += nums[i][j];
            }
            res = Math.max(sum,res);
        }
        return res;
    }
}
