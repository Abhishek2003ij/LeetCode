class Solution {
    public int numIdenticalPairs(int[] nums) {
        int res =0;
        int n = nums.length;
        Map<Integer, Integer> map = new HashMap<>();
        for(int i=0;i<n;i++){
            int temp = nums[i];
            if(map.containsKey(temp)){
                res += map.get(temp);
            }
            map.put(temp,map.getOrDefault(temp,0)+1);
        }
        return res;
        
    }
}
