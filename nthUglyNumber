class Solution {
    public int nthUglyNumber(int n) {
        if(n == 1 || n == 0) return n;
        int[] temp = new int[1690];
        int p2 = 0, p3 = 0, p5 = 0;
        temp[0] = 1;
        for(int i = 1; i < n; i++){
            temp[i] = Math.min(temp[p2]*2, Math.min(temp[p3]*3, temp[p5]*5));
            if(temp[i] == temp[p2]*2) p2++;
            if(temp[i] == temp[p3]*3) p3++;
            if(temp[i] == temp[p5]*5) p5++;
        }
        return temp[n-1];
    }
}
