class Solution { 
    public int missingNumber(int[] nums) { 
        int n = nums.length; 
        int j = 0; 
        
        while (j < n) { 
            // Fix 1 & 2: Bound check, and ensure target position does not already hold the value
            if (nums[j] < n && nums[j] != nums[nums[j]]) { 
                // Fix 3: Direct swap without using any new helper variables
                int temp = nums[j]; 
                nums[j] = nums[temp]; 
                nums[temp] = temp; 
            } else { 
                j++; 
            } 
        } 
        
        for (int i = 0; i < n; i++) { 
            if (nums[i] != i) { 
                return i; 
            } 
        } 
        
        // Fix 4: If all indices match, 'n' is the missing number
        return n; 
    } 
}
