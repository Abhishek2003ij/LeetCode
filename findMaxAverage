class Solution {
    public double findMaxAverage(int[] nums, int k) {
        double res = 0;
        double temp =0;
        int n = nums.length;
        for(int i=0;i<k;i++) temp += nums[i];
        res = temp/k;
        for(int i=k;i<n;i++)
        {
            temp -= nums[i-k];
            temp += nums[i];
            if(res<temp/k) res = temp/k;
        }
        return res;
        
    }
}
