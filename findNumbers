class Solution {
    public int findNumbers(int[] nums) {
        int n = nums.length;
        int res =0;
        for(int i=0;i<n;i++)
        {
            int ele = nums[i];
            String temp = String.valueOf(ele);
            if(temp.length() % 2==0) res++;
        }
        return res;
        
    }
}
