class Solution {
    public long zeroFilledSubarray(int[] nums) {
            long res =0;
            int temp=0;
            int n = nums.length;
            for(int i=0;i<n;i++)
            {
             if(nums[i]==0){
                temp++;
                res += temp;
             }
             else{
                temp =0;
             }
            }  
            return res;
    }
}
