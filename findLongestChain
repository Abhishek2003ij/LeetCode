class Solution {
    public int findLongestChain(int[][] pairs) {
        Arrays.sort(pairs,(a,b)->Integer.compare(a[1],b[1]));
        int temp = Integer.MIN_VALUE, res =0;
        for(int[] cur:pairs){
            if(temp<cur[0]){
                temp = cur[1];
                res++;
            }
        }
        return res;
        
    }
}
